// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())

  produtos Produto[]
}

model Produto {
  id          String    @id @default(cuid())
  nome        String
  slug String @unique
  tamanho     String?
  descricao   String?
  cor          String?
  referencia   String?          @unique
  marca       String?
  preco       Decimal @db.Decimal(10,2)
  tipo        ProdutoTipo @default(BRECHO)
  status      ProdutoStatus @default(DISPONIVEL)
  estoque Int @default(1)
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  imagens     ProdutoImagem[]
  pedidoItens PedidoItem[]
  updatedAt DateTime @updatedAt
  createdAt   DateTime @default(now())
}

enum ProdutoTipo {
  BRECHO
  NA_ETIQUETA
}

enum ProdutoStatus {
  DISPONIVEL
  RESERVADO
  VENDIDO
}

model ProdutoImagem {
  id        String @id @default(cuid())

  url       String

  publicId  String

  produtoId String

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  ordem     Int @default(0)

  createdAt DateTime @default(now())
}

model Usuario {
  id        String   @id @default(cuid())

  nome      String
  email     String   @unique
  senha     String

  role      UserRole @default(CLIENTE)

  enderecos Endereco[]
  pedidos   Pedido[]

  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  CLIENTE
}

model Endereco {
  id          String   @id @default(cuid())

  cep         String

  logradouro  String
  numero      String

  complemento String?

  bairro      String
  cidade      String
  estado      String

  usuarioId   String

  usuario     Usuario @relation(fields: [usuarioId], references: [id])

  createdAt   DateTime @default(now())
}

model Pedido {
  id         String   @id @default(cuid())

  usuarioId  String

  usuario    Usuario @relation(fields: [usuarioId], references: [id])

  status     PedidoStatus @default(PIX_PENDENTE)

  frete Decimal @db.Decimal(10,2) @default(0)

  total      Decimal @db.Decimal(10,2)

  itens      PedidoItem[]

  createdAt  DateTime @default(now())
}

enum PedidoStatus {
  PIX_PENDENTE
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}

model PedidoItem {
  id             String   @id @default(cuid())

  pedidoId       String
  produtoId      String

  pedido         Pedido  @relation(fields: [pedidoId], references: [id])
  produto        Produto @relation(fields: [produtoId], references: [id])

  precoUnitario  Decimal @db.Decimal(10,2)

  createdAt      DateTime @default(now())
}

model InspiracaoSemana {
  id          String   @id @default(cuid())

  titulo      String

  descricao   String?

  imagemUrl   String

  ativo       Boolean @default(false)

  createdAt   DateTime @default(now())
}
